# Copy this file to .env and fill in your values
# Get a free RPC URL from Infura (https://app.infura.io) or Alchemy (https://www.alchemy.com)

# Ethereum RPC endpoint (leave empty to run in demo/simulation mode)
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# Optional: Alchemy alternative
# ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
